@model SistemaChatbot.Models.EnderecoModel

@{
    ViewData["Title"] = "Dados Recebidos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-success">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">✅ Dados Recebidos no Servidor (Somente Leitura)</h3>
                </div>
                <div class="card-body bg-light">
                    <p class="fs-5">O formulário foi enviado com sucesso utilizando <strong>Model Binding</strong> no ASP.NET MVC. Os dados abaixo combinam a API externa com o input do cliente:</p>
                    <hr />
                    
                    <ul class="list-group list-group-flush fs-5">
                        <li class="list-group-item"><strong>CEP:</strong> @Model.Cep</li>
                        <li class="list-group-item"><strong>Logradouro:</strong> @Model.Logradouro</li>
                        <li class="list-group-item"><strong>Bairro:</strong> @Model.Bairro</li>
                        <li class="list-group-item"><strong>Cidade/Localidade:</strong> @Model.Localidade</li>
                        <li class="list-group-item"><strong>Estado (UF):</strong> @Model.Uf</li>
                        <li class="list-group-item"><strong>Número Cadastrado:</strong> <span class="badge bg-primary">@Model.Numero</span></li>
                    </ul>

                    <div class="mt-4 text-center">
                        <a asp-action="Index" class="btn btn-outline-secondary">Realizar Nova Busca</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>